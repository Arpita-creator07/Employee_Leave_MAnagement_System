{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Flask app",
      "type": "shell",
      "command": "${workspaceFolder}\\venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "flask",
        "--app",
        "app",
        "run",
        "--debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
